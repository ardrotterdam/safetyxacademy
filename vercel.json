{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.safetyxacademy.nl" }],
      "destination": "https://safetyxacademy.nl/:path*",
      "statusCode": 301
    },

    {
      "source": "/index.html",
      "destination": "/",
      "statusCode": 301
    },
    {
      "source": "/blog/index.html",
      "destination": "/blog/",
      "statusCode": 301
    },
    {
      "source": "/blog/index.php",
      "destination": "/blog/",
      "statusCode": 301
    },
    {
      "source": "/blog/veiligheidskundige-opleiding",
      "destination": "/blog/veiligheidskundige-opleiding/",
      "statusCode": 410
    },
    {
      "source": "/blog/veiligheidskundige-opleiding/",
      "destination": "/blog/veiligheidskundige-opleiding/",
      "statusCode": 410
    },
    {
      "source": "/blog/veiligheidskundige-opleiding/index.html",
      "destination": "/blog/veiligheidskundige-opleiding/",
      "statusCode": 410
    },
    {
      "source": "/blog/veiligheidskundige-opleiding/index.php",
      "destination": "/blog/veiligheidskundige-opleiding/",
      "statusCode": 410
    },
    {
      "source": "/blog/nebosh-student-guide-rotterdam-westplein-veerhaven.html",
      "destination": "/blog/nebosh-student-guide-rotterdam-lunch-landmarks/",
      "statusCode": 301
    },
    {
      "source": "/blog/nebosh-student-guide-rotterdam-lunch-landmarks/index.html",
      "destination": "/blog/nebosh-student-guide-rotterdam-lunch-landmarks/",
      "statusCode": 301
    },
    {
      "source": "/blog/nebosh-student-guide-rotterdam-lunch-landmarks/index.php",
      "destination": "/blog/nebosh-student-guide-rotterdam-lunch-landmarks/",
      "statusCode": 301
    },
    {
      "source": "/blog/arbowet-wijziging-1-juli-2026/index.html",
      "destination": "/blog/arbowet-wijziging-1-juli-2026/",
      "statusCode": 301
    },
    {
      "source": "/blog/nebosh-igc-complete-gids-2026/index.html",
      "destination": "/blog/nebosh-igc-complete-gids-2026/",
      "statusCode": 301
    },
    {
      "source": "/blog/veiligheidskundige-salaris-2026/index.html",
      "destination": "/blog/veiligheidskundige-salaris-2026/",
      "statusCode": 301
    },

    {
      "source": "/aanmelden",
      "destination": "/aanmelden.html",
      "statusCode": 301
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
